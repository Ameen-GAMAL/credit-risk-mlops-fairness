# Copy to .env (gitignored) and fill in. Without these, everything still
# works fully offline against local ./mlruns tracking.

# DagsHub-hosted MLflow (Settings -> Tokens on dagshub.com for the token)
MLFLOW_TRACKING_URI=https://dagshub.com/s-amin.mohamed/credit-risk-mlops-fairness.mlflow
MLFLOW_TRACKING_USERNAME=s-amin.mohamed
MLFLOW_TRACKING_PASSWORD=your-fresh-dagshub-token

# Same token, used by DVC remote auth and the Docker build secret
DAGSHUB_TOKEN=your-fresh-dagshub-token

# Serving (dev mode): which MLflow run to load
# RUN_ID=abc123...
# MODEL_DIR=artifacts/model_download/model
