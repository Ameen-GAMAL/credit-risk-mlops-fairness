# TEMPLATE ONLY — never commit a real secret.yaml (it is gitignored).
#
# Only needed for the alternative "fetch model at container start" mode
# (RUN_ID env + live MLflow access instead of a baked model). The default
# deployment bakes the model at image build time and needs no secret.
#
# Preferred: create imperatively instead of via a file at all:
#   kubectl create secret generic dagshub-credentials \
#     --from-literal=token=<YOUR_FRESH_DAGSHUB_TOKEN> \
#     -n credit-risk-mlops
apiVersion: v1
kind: Secret
metadata:
  name: dagshub-credentials
  namespace: credit-risk-mlops
type: Opaque
stringData:
  token: REPLACE_WITH_FRESH_DAGSHUB_TOKEN
